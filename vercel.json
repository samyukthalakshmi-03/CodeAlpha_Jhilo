{
  "version": 2,
  "builds": [
    { "src": "api/[...slug].js", "use": "@vercel/node" },
    { "src": "client/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/api$", "dest": "/api/[...slug].js" },
    { "src": "^/api/(.*)$", "dest": "/api/[...slug].js" },
    { "src": "^/(.*)$", "dest": "/client/$1" }
  ]
}
